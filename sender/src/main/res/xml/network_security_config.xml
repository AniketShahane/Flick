<?xml version="1.0" encoding="utf-8"?>
<!--
  The sender is a *server*, not a client: it hosts an embedded Ktor CIO listening
  socket on the LAN and makes NO outbound platform HTTP of its own. Android's
  network-security-config governs only the app's OWN outbound traffic — it does
  NOT apply to the bytes served over the CIO server socket — so forbidding
  cleartext here does not affect (and cannot break) the plain-http LAN serving the
  TV consumes.

  We therefore set cleartextTrafficPermitted="false": with no outbound cleartext
  anywhere in the app, this closes the door on any accidental future plaintext
  request while leaving the LAN media server fully functional. System trust anchors
  are kept for any TLS the platform might do.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
